    #showme {=== TARGET STATUS ===};
    #showme {Squad      : $sq_name};
    #showme {Fighter    : $sq_num};
    #showme {Max found  : $sq_max};
    #showme {Ceiling    : $SQ_CEIL};
    #showme {Floor      : $SQ_FLOOR};
    #showme {Delay      : $SQ_PROBE_DELAY};
    #showme {Last target: $last_target};
    #showme {Probing    : $tgt_probing};
    #showme {Auto relock: $auto_retarget};
    #showme {====================}
}