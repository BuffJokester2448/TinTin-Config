#nop ==============================
#nop  LOTJ Space Combat Macros
#nop  Based on official LOTJ fleet
#nop  combat guide commands
#nop ==============================

#nop ==============================
#nop  NAVIGATION
#nop ==============================

#nop Basic movement
#alias {co}   {course %1 %2 %3}
#alias {sp}   {speed %1}
#alias {spmax}{speed 400}
#alias {spstop}{speed 0}
#alias {sp1}  {speed 1}
#alias {spc} {speed 40}
#alias {vec}  {vector %1 %2 %3}
#alias {prox} {proximity}
#alias {ht}   {hyperspace %1 %2 %3}
#alias {apon} {autopilot on}
#alias {apoff}{autopilot off}
#alias {orbit}{orbit %1}
#alias {rl} {roll}

#nop ==============================
#nop  FACING / TURNING
#nop  FACE turns toward a ship
#nop  COURSE turns toward coordinates
#nop ==============================

#nop Face a specific ship
#alias {fc}    {face %1}

#nop Face current target
#alias {fct}   {face $current_target}

#nop Course to coordinates
#alias {co}    {course %1 %2 %3}

#nop Course to named object or planet
#alias {cop}   {course %1}

#nop ==============================
#nop  AUTO HYPERSPACE ALIAS
#nop  Sets speed 1 before jumping
#nop  for entire battlegroup
#nop ==============================

#alias {bghyp} {
    battlegroup nav all speed 1;
    speed 1;
    #delay 1 {
        battlegroup nav all hyperspace;
        hyperspace;
        #showme {<103>[ Battlegroup jumping ]}
    }
}

#alias {hyp} {
    speed 1;
    #delay 1 {
        hyperspace;
        #showme {<103>[ Jumping to hyperspace ]}
    }
}

#nop ==============================
#nop  Auto Face on Target
#nop ==============================
#var current_target {}
#var autoface {0}

#nop Toggle auto face on/off
#alias {afon}  {
    #var autoface {1};
    #showme {<102>[ Auto face ON ]}
}
#alias {afoff} {
    #var autoface {0};
    #showme {<102>[ Auto face OFF ]}
}

#nop Override target alias to also face
#alias {tg} {
    #var current_target {%1};
    target %1;
    #if {$autoface == 1} {
        face %1;
        #showme {<103>[ Targeting and facing: %1 ]}
    }
}

#nop Battlegroup target with auto face
#alias {bgt} {
    #var current_target {%1};
    battlegroup target all %1;
    target %1;
    #if {$autoface == 1} {
        face %1
    }
}

#nop ==============================
#nop  Re-face after position change
#nop ==============================
#event {IAC SB MSDP MSDP_VAR SHIPSYSX MSDP_VAL %1 IAC SE} {
    #var ship_x {%1};
    #if {$autoface == 1 && $current_target != {}} {
        face $current_target
    }
}

#nop ==============================
#nop  WEAPONS AND COMBAT
#nop ==============================

#nop Targeting
#alias {tg}   {target %1}
#alias {tgc}  {target clear}

#nop Fire individual weapons
#alias {fi}   {fire}
#alias {fl}   {fire laser}
#alias {fion} {fire ion}
#alias {fm}   {fire missile}
#alias {ft}   {fire torpedo}
#alias {fr}   {fire rocket}

#nop Fire all weapons at once
#alias {fall} {
    fire;
    fire laser;
    fire ion;
    fire missile;
    fire torpedo;
    fire rocket
}

#nop Chaff
#alias {ch}   {chaff}

#nop ==============================
#nop  SHIELDS
#nop ==============================

#alias {rc}   {recharge}
#alias {shld} {shield}

#nop MSDP shield warning
#nop Alerts when shields drop low
#event {IAC SB MSDP MSDP_VAR SHIPSHIELD MSDP_VAL %1 IAC SE} {
    #var cur_shield {%1};
    #if {%1 < 20 && $in_space == 1} {
        #showme {<101>[ WARNING: SHIELDS LOW: %1 ]};
        #script {shieldwarn} {termux-notification --title "LOTJ" --content "Shields critical"}
    }
}

#nop Hull warning
#event {IAC SB MSDP MSDP_VAR SHIPHULL MSDP_VAL %1 IAC SE} {
    #var cur_hull {%1};
    #if {%1 < 20 && $in_space == 1} {
        #showme {<101>[ WARNING: HULL CRITICAL: %1 ]}
    }
}

