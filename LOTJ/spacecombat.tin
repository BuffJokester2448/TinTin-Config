#nop Status
#alias {bg}      {battlegroup}
#alias {bgstat}  {battlegroup}

#nop Join and quit
#alias {bgjoin}  {battlegroup join %1}
#alias {bgquit}  {battlegroup quit}
#alias {bgej}    {battlegroup eject %1}

#nop Positioning
#alias {bgpos}   {battlegroup position %1}
#alias {bgin}    {battlegroup position 3}
#alias {bgmid}   {battlegroup position 2}
#alias {bgout}   {battlegroup position 1}

#nop Autopilot across battlegroup
#alias {bgaon}   {battlegroup nav all autopilot on;autopilot on}
#alias {bgaoff}  {battlegroup nav all autopilot off;autopilot off}

#nop Targeting across battlegroup
#alias {bgt}      {battlegroup target %1 %2}
#alias {bgta}     {battlegroup target all %1;target %1}

#nop Fire all ships in battlegroup
#alias {bgf}     {
    battlegroup nav all fire;fire;
    battlegroup nav all fire laser;fire laser;
    battlegroup nav all fire ion;fire ion;
    battlegroup nav all fire missile;fire missile;
    battlegroup nav all fire torpedo;fire torpedo;
    battlegroup nav all fire rocket;fire rocket
}

#nop Movement
#alias {bgco}    {battlegroup nav all course %1 %2 %3;course %1 %2 %3}
#alias {bgsp}    {battlegroup nav all speed %1;speed %1}
#alias {bgvec}   {battlegroup nav %1 vector %2 %3 %4}
#alias {bgprox}  {battlegroup nav all proximity;proximity}

#nop Split battlegroup for hyperspace
#nop Uses max speed of slowest ship
#nop Replace SLOWSPEED with actual value
#alias {bgsplit} {
    battlegroup nav all speed SLOWSPEED;
    speed SLOWSPEED;
    battlegroup nav WINGSHIP1 vector 50000 0 0;
    battlegroup nav WINGSHIP2 vector 0 50000 0;
    vector 0 0 50000
}

#nop Jump battlegroup to hyperspace
#alias {bghyp}   {
    battlegroup nav all speed 1;
    speed 1;
    battlegroup nav all hyperspace;
    hyperspace
}

#nop Nav command to single ship in battlegroup
#alias {bgnav}   {battlegroup nav %1 %2}

#nop Chaff across battlegroup
#alias {bgch}    {battlegroup nav all chaff;chaff}

#nop Recharge across battlegroup
#alias {bgrc}    {battlegroup nav all recharge;recharge}

#nop ==============================
#nop  COMBAT STATUS DISPLAY
#nop ==============================

#nop Quick status check alias
#alias {combstat} {
    #showme {=== COMBAT STATUS ===};
    #showme {Shield : $cur_shield};
    #showme {Hull   : $cur_hull};
    #showme {Speed  : $MSDP_SHIPSPEED};
    #showme {System : $ship_sys};
    #showme {Coords : X$ship_x Y$ship_y Z$ship_z};
    #showme {====================}
}

#nop ==============================
#nop  COMBAT MACROS
#nop  Combined action sequences
#nop ==============================

#nop Emergency recharge and chaff
#alias {panic} {
    recharge;
    recharge shields;
    chaff;
    #showme {<101>[ PANIC: Recharging and chaffing ]}
}

#nop Full engage with face first
#alias {engage} {
    #var current_target {%1};
    face %1;
    target %1;
    fire;
    fire laser;
    fire ion;
    fire missile;
    squadron target 1 %1;
    squadron target 2 %1;
    squadron target 3 %1;
    squadron fire 1;
    squadron fire 2;
    squadron fire 3;
    #showme {<103>[ Facing and engaging: %1 ]}
}

#nop Battlegroup full engage
#alias {bgengage} {
    battlegroup target all %1;
    target %1;
    battlegroup nav all fire;fire;
    battlegroup nav all fire laser;fire laser;
    battlegroup nav all fire missile;fire missile;
    #showme {<103>[ Battlegroup engaging: %1 ]}
}

#nop Retreat sequence
#alias {runaway} {
    speed 500;
    battlegroup nav all speed 500;
    chaff;
    battlegroup nav all chaff;
    #showme {<101>[ RETREATING ]}
}
